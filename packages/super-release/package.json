{
  "name": "super-release",
  "type": "module",
  "version": "1.2.0",
  "bin": {
    "super-release": "npm/bin/super-release.js"
  },
  "description": "A fast semantic-release alternative for monorepos, written in Rust",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "npm/bin",
    "README.md"
  ],
  "keywords": [
    "semantic-release",
    "monorepo",
    "release",
    "changelog",
    "conventional-commits"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BowlingX/super-release.git"
  },
  "scripts": {
    "super-release": "node npm/bin/super-release.js"
  },
  "optionalDependencies": {
    "super-release-linux-x64": "workspace:*",
    "super-release-linux-arm64": "workspace:*",
    "super-release-darwin-x64": "workspace:*",
    "super-release-darwin-arm64": "workspace:*",
    "super-release-windows-x64": "workspace:*"
  }
}
