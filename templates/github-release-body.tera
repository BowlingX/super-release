- @{{ contributor.username }} made their first contribution{% if contributor.pr_number %} in [#{{ contributor.pr_number }}]({{ extra.repo_url }}/pull/{{ contributor.pr_number }}){% endif %}
{%- endfor %}
{% endif -%}
{% set contributors = github.contributors | filter(attribute="username") -%}
